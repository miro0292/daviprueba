PORT=3000
SERVICE_NAME=auth-service

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cifrado de sesión (AES-256-GCM — debe ser exactamente 32 chars)
SESSION_ENCRYPTION_KEY=change_this_key_32_chars_exactly!

# TTL de sesión en segundos (30 minutos)
SESSION_TTL_SECONDS=1800

# URL del Core Usuarios
CORE_USUARIOS_URL=http://localhost:5001

# Circuit Breaker
CB_TIMEOUT_MS=5000
CB_ERROR_THRESHOLD=50
CB_RESET_TIMEOUT_MS=30000
CB_MAX_RETRIES=3
CB_RETRY_DELAY_MS=1000

LOG_LEVEL=info
