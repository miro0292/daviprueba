# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=financial_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis123

# ── Sesión (AES-256-GCM — exactamente 32 caracteres) ────────────────────────
SESSION_ENCRYPTION_KEY=FinancialApp_SecretKey_32chars!!

# ── Auth Service ─────────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=1800
MAX_FAILED_ATTEMPTS=5

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CB_TIMEOUT_MS=5000
CB_ERROR_THRESHOLD=50
CB_RESET_TIMEOUT_MS=30000
CB_MAX_RETRIES=3
CB_RETRY_DELAY_MS=1000
